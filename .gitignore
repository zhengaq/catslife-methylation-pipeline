# Site/server path profile — never commit (environment-specific paths)
config.site.R

# Data & outputs — never commit (governance + size)
/data/
/output/
*.RDat
*.RData
*.rds
*.txt
*.sav
*.xlsx
*.pdf
*.png

# Run logs + orchestrator checkpoints (run_stage5_pipeline.sh writes logs/ and logs/.ckpt/)
/logs/
*.log

# ExperimentHub / AnnotationHub caches
.cache/

# Dev / agent tooling. .agents/.claude/.lavish ARE versioned in this (private) dev
# repo and kept out of the public runtime via .runtimeignore, so they are deliberately
# NOT ignored here (a path in .runtimeignore must not also be in .gitignore).
/skills-lock.json

# R session cruft
.Rhistory
.RData
.Rproj.user/
Rplots.pdf

# renv library (lockfile, if added, IS tracked)
renv/library/
renv/staging/
